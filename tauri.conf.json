{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Window Inspector",
  "version": "0.1.0",
  "identifier": "com.example.window-inspector",
  "build": {
    "frontendDist": "ui"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Window Inspector",
        "width": 1200,
        "height": 720,
        "resizable": true,
        "visible": true,
        "backgroundColor": "#1e1e2e"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
